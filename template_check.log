# Source: canary/templates/httproute.yaml
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: release-name-canary
  labels:
    helm.sh/chart: canary-0.1.2
    app.kubernetes.io/name: canary
    app.kubernetes.io/instance: release-name
    app.kubernetes.io/version: "1.16.0"
    app.kubernetes.io/managed-by: Helm
spec:
  parentRefs:
    - name: canary
      namespace: istio-ingress
  hostnames:
    - nginx.aaronwasson.net
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: release-name-canary
          port: 80
          weight: 8
        - name: release-name-canary-v2
          port: 80
          weight: 2
