# Source: canary/templates/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: release-name-canary
  labels:
    helm.sh/chart: canary-0.1.2
    app.kubernetes.io/name: canary
    app.kubernetes.io/instance: release-name
    app.kubernetes.io/version: "1.16.0"
    app.kubernetes.io/managed-by: Helm
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: canary
      app.kubernetes.io/instance: release-name
  template:
    metadata:
      labels:
        helm.sh/chart: canary-0.1.2
        app.kubernetes.io/name: canary
        app.kubernetes.io/instance: release-name
        app.kubernetes.io/version: "1.16.0"
        app.kubernetes.io/managed-by: Helm
    spec:
      serviceAccountName: release-name-canary
      containers:
        - name: canary
          image: "nginx:1.16.0"
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 80
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /
              port: http
          readinessProbe:
            httpGet:
              path: /
              port: http
          resources:
            limits:
              cpu: 100m
              memory: 128Mi
            requests:
              cpu: 100m
              memory: 128Mi
          volumeMounts:
            - mountPath: /etc/nginx/conf.d/default.conf
              name: default-conf
              subPath: default.conf
      volumes:
        - configMap:
            name: nginx-conf
          name: default-conf
